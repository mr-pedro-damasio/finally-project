backend/.venv/
backend/__pycache__/
backend/**/__pycache__/
backend/db/

# Node modules and Next.js cache (rebuilt in Docker)
frontend/node_modules/
frontend/.next/
frontend/out/

# Local DB and secrets
db/
.env

# Git and IDE
.git/
.gitignore
**/.DS_Store
